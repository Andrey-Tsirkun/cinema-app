{
  "name": "cinema-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:all": "docker compose up postgres redis -d --wait && npm run dev:all:db && npm run dev:all:app",
    "dev:all:db": "env-cmd -f apps/backend/docker.local.env npm run db:prepare -w backend && env-cmd -f apps/backend/docker.local.env npm run db:seed -w backend",
    "dev:all:app": "env-cmd -f apps/backend/docker.local.env npm run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:seed": "npm run db:seed -w backend",
    "docker:build": "docker compose build",
    "docker:build:nocache": "docker compose build --no-cache",
    "docker:up": "docker compose up",
    "docker:up:detached": "docker compose up -d",
    "docker:up:build": "docker compose up --build",
    "docker:up:build:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:stop": "docker compose stop",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:clean": "docker compose down -v",
    "docker:db:reset": "docker compose down -v && docker compose up postgres redis -d --wait",
    "docker:infra:up": "docker compose up postgres redis -d",
    "docker:infra:down": "docker compose stop postgres redis"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "env-cmd": "^10.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
