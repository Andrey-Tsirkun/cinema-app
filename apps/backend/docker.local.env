# Used by `npm run dev:all` (dotenv-cli --override) so DB URL matches docker-compose defaults.
# Host port published by compose: Postgres 5433 → container 5432.
DATABASE_URL=postgresql://cinema:cinema@127.0.0.1:5433/cinema?schema=public&sslmode=disable
JWT_SECRET=dev-only-change-in-production
JWT_EXPIRES_IN=7d
