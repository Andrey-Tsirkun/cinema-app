# Copy to .env for local runs. One-shot stack: from repo root run `npm run dev:all` (Docker Postgres+Redis, migrations, seed, fe+be).
# Re-run seed on non-empty DB: SEED_FORCE=true npm run db:seed -w backend (wipes movies/halls/seats/sessions/reservations).
DATABASE_URL=postgresql://cinema:cinema@localhost:5432/cinema?schema=public
SESSION_SECRET=replace-with-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

FRONTEND_ORIGIN=http://localhost:3000
OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000

# Required in production (shared sessions across replicas). Optional locally (falls back to memory).
REDIS_URL=redis://localhost:6379

# Set to "true" behind a reverse proxy so rate limits use X-Forwarded-For correctly.
# TRUST_PROXY=true

# Optional. Hold duration for new reservations in ms (default 300000 = 5 minutes).
# RESERVATION_HOLD_MS=300000

PORT=4000
