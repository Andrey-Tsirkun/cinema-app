# PostgreSQL (docker-compose service name: postgres)
POSTGRES_USER=cinema
POSTGRES_PASSWORD=cinema
POSTGRES_DB=cinema

# Prisma / backend — Docker network host is "postgres"; on host machine use "localhost"
DATABASE_URL=postgresql://cinema:cinema@postgres:5432/cinema?schema=public
# DATABASE_URL=postgresql://cinema:cinema@localhost:5432/cinema?schema=public

# Backend auth placeholder (no auth logic in this scaffold)
JWT_SECRET=change-me-in-production
