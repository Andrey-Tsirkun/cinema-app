# PostgreSQL (docker-compose service name: postgres)
POSTGRES_USER=cinema
POSTGRES_PASSWORD=cinema
POSTGRES_DB=cinema

# Prisma / backend — in Compose, backend uses hostname "postgres" on internal port 5432; on the host use localhost:5433 (mapped in compose).
DATABASE_URL=postgresql://cinema:cinema@postgres:5432/cinema?schema=public
# DATABASE_URL=postgresql://cinema:cinema@localhost:5433/cinema?schema=public

# Backend JWT signing (required by apps/backend)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
