# PostgreSQL (docker-compose service name: postgres)
POSTGRES_USER=cinema
POSTGRES_PASSWORD=cinema
POSTGRES_DB=cinema

# Prisma / backend — in Compose, backend uses hostname "postgres" on internal port 5432; on the host use localhost:5433 (mapped in compose).
DATABASE_URL=postgresql://cinema:cinema@postgres:5432/cinema?schema=public
# DATABASE_URL=postgresql://cinema:cinema@localhost:5433/cinema?schema=public

# Backend JWT signing (required by apps/backend)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- docker-compose.prod.yml (VPS) ---
# Required in .env: POSTGRES_PASSWORD, JWT_SECRET, FRONTEND_ORIGIN, NEXT_PUBLIC_API_URL
# FRONTEND_ORIGIN = browser origin for CORS (e.g. https://cinema.example.com)
# NEXT_PUBLIC_API_URL = full public URL of the API for the browser (e.g. https://api.example.com or https://cinema.example.com:4000); baked into the frontend image at build time
# Optional: TRUST_PROXY (defaults to true in prod compose; use behind Nginx)
