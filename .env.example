# PostgreSQL (docker-compose service name: postgres)
POSTGRES_USER=cinema
POSTGRES_PASSWORD=cinema
POSTGRES_DB=cinema

# Prisma / backend — in Compose, backend uses hostname "postgres" on internal port 5432; on the host use localhost:5433 (mapped in compose).
DATABASE_URL=postgresql://cinema:cinema@postgres:5432/cinema?schema=public
# DATABASE_URL=postgresql://cinema:cinema@localhost:5433/cinema?schema=public

# Backend JWT signing (required by apps/backend)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== Production VPS (docker-compose.prod.yml), IP like scheduler ==========
# Copy repo to server, then from repo root:
#   cp .env.example .env
# Edit .env: set YOUR_IP (replace 155.212.244.111), then:
#   docker compose -f docker-compose.prod.yml up --build -d
# Host Nginx on :80 (containers bind 127.0.0.1 only): sudo bash scripts/setup-nginx.sh YOUR_IP
# Do not use $ inside passwords (Compose treats $ as variable interpolation).
#
# With Nginx, the browser opens http://YOUR_IP/ (frontend). API base must include /api path:
# FRONTEND_ORIGIN=http://155.212.244.111
# NEXT_PUBLIC_API_URL=http://155.212.244.111/api
#
# Required for prod compose (example values — change IP and secrets):
# POSTGRES_PASSWORD=cinema
# JWT_SECRET=change-me-jwt-secret
# FRONTEND_ORIGIN=http://155.212.244.111
# NEXT_PUBLIC_API_URL=http://155.212.244.111/api
# Optional: TRUST_PROXY=true (default in docker-compose.prod.yml behind Nginx)
